---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Location & Hours" description="Find Bright Smiles Dental Clinic in Koramangala, Bengaluru. View our map, opening hours, and get directions.">

  <div class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">Home</a> <span>/</span> <span>Location</span></div>
      <h1>Find Our Clinic</h1>
      <p>Conveniently located in Koramangala, Bengaluru — easy access by metro, auto, or bus.</p>
    </div>
  </div>

  <section class="section" style="padding-top:3rem;">
    <div class="container">
      <div class="location-grid">

        <!-- MAP -->
        <div class="map-col">
          <div class="map-card card">
            <div id="map" class="map-embed"></div>
            <div class="map-footer">
              <a href="https://maps.google.com/?q=Koramangala+Bengaluru" target="_blank" class="btn btn--primary" style="width:100%;justify-content:center;" id="directions-btn">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <polygon points="3 11 22 2 13 21 11 13 3 11"/>
                </svg>
                Get Directions on Google Maps
              </a>
            </div>
          </div>
        </div>

        <!-- INFO COLUMN -->
        <div class="info-col">

          <!-- Address -->
          <div class="info-card card">
            <div class="info-card-head">
              <div class="info-ico">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <h3>Our Address</h3>
            </div>
            <address>
              <strong>Bright Smiles Dental Clinic</strong><br/>
              123 Smile Street, 6th Block<br/>
              Koramangala, Bengaluru<br/>
              Karnataka 560034, India
            </address>
            <div class="transport-list">
              <div class="transport-item">
                <div class="t-dot"></div>
                <div>
                  <strong>By Metro</strong>
                  <span>Jayanagar Metro Station — 10-minute auto ride</span>
                </div>
              </div>
              <div class="transport-item">
                <div class="t-dot"></div>
                <div>
                  <strong>By Car / Auto</strong>
                  <span>Free parking available in clinic premises</span>
                </div>
              </div>
              <div class="transport-item">
                <div class="t-dot"></div>
                <div>
                  <strong>By Bus</strong>
                  <span>BMTC stops at Koramangala Bus Stand, 200m away</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Hours -->
          <div class="info-card card" style="margin-top:1.25rem;">
            <div class="info-card-head">
              <div class="info-ico">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
              </div>
              <h3>Opening Hours</h3>
            </div>
            <div class="hours-table">
              {[
                { day: 'Monday',    hours: '9:00 AM – 7:00 PM', open: true  },
                { day: 'Tuesday',   hours: '9:00 AM – 7:00 PM', open: true  },
                { day: 'Wednesday', hours: '9:00 AM – 7:00 PM', open: true  },
                { day: 'Thursday',  hours: '9:00 AM – 7:00 PM', open: true  },
                { day: 'Friday',    hours: '9:00 AM – 7:00 PM', open: true  },
                { day: 'Saturday',  hours: '9:00 AM – 4:00 PM', open: true  },
                { day: 'Sunday',    hours: 'Closed',             open: false },
              ].map(h => (
                <div class={`h-row ${!h.open ? 'h-row--closed' : ''}`}>
                  <span class="h-day">{h.day}</span>
                  <span class="h-time">
                    {h.open && <span class="h-dot"></span>}
                    {h.hours}
                  </span>
                </div>
              ))}
            </div>
            <div class="emergency-note">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
              <span>Dental emergency? Call anytime — <a href="tel:+60312345678">+603-1234 5678</a></span>
            </div>
          </div>

          <!-- Contact Quick Buttons -->
          <div class="info-card card" style="margin-top:1.25rem;">
            <div class="info-card-head">
              <div class="info-ico">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .84h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 8.18a16 16 0 006.91 6.91l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
                </svg>
              </div>
              <h3>Contact Us</h3>
            </div>
            <div class="quick-btns">
              <a href="tel:+918012345678" class="quick-btn" id="loc-phone-btn">
                <div class="qb-ico qb-phone">
                  <svg width="16" height="16" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .84h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 8.18a16 16 0 006.91 6.91l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                </div>
                <div><strong>Call</strong><span>+91 80-1234 5678</span></div>
              </a>
              <a href="https://wa.me/919912837875" target="_blank" class="quick-btn" id="loc-wa-btn">
                <div class="qb-ico qb-wa">
                  <svg width="16" height="16" fill="white" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </div>
                <div><strong>WhatsApp</strong><span>+91 98765 43210</span></div>
              </a>
              <a href="mailto:hello@brightsmilesdental.in" class="quick-btn" id="loc-email-btn">
                <div class="qb-ico qb-email">
                  <svg width="16" height="16" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <div><strong>Email</strong><span>hello@brightsmilesdental.com</span></div>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEARBY -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">Getting Here</div>
        <h2>Nearby Landmarks</h2>
        <div class="divider"></div>
      </div>
      <div class="grid-4">
        {[
          { label: 'Forum',  name: 'Forum Mall Koramangala',  dist: '100m from clinic' },
          { label: 'METRO', name: 'Jayanagar Metro Station',   dist: '10-min auto ride' },
          { label: 'AIIMS', name: 'Sakra World Hospital',      dist: '1.2km from clinic' },
          { label: 'PKG',   name: 'Free Clinic Parking',       dist: 'On-site parking available' },
        ].map(l => (
          <div class="landmark card" style="padding:1.5rem;text-align:center;">
            <div class="landmark-abbr">{l.label}</div>
            <strong style="display:block;margin-bottom:0.3rem;">{l.name}</strong>
            <span style="font-size:0.82rem;color:var(--text-muted);">{l.dist}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
.location-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start; }
.map-card { overflow: hidden; }
.map-embed { width: 100%; height: 420px; border: none; display: block; }
.map-footer { padding: 1rem; }

.info-card { padding: 1.5rem; }
.info-card-head { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.1rem; }
.info-ico { width: 36px; height: 36px; background: var(--primary-pale); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--primary); flex-shrink: 0; }
.info-card-head h3 { font-size: 1rem; margin: 0; }
address { font-style: normal; font-size: 0.88rem; color: var(--text-muted); line-height: 1.8; margin-bottom: 1.1rem; }
address strong { color: var(--text); }

.transport-list { display: flex; flex-direction: column; gap: 0.7rem; }
.transport-item { display: flex; align-items: flex-start; gap: 0.75rem; font-size: 0.85rem; }
.t-dot { width: 8px; height: 8px; background: var(--primary); border-radius: 50%; flex-shrink: 0; margin-top: 5px; }
.transport-item strong { display: block; font-size: 0.85rem; color: var(--text); }
.transport-item span   { font-size: 0.8rem; color: var(--text-muted); }

.hours-table { display: flex; flex-direction: column; }
.h-row { display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid var(--border); font-size: 0.85rem; }
.h-row:last-child { border-bottom: none; }
.h-row--closed { opacity: 0.55; }
.h-day  { color: var(--text-muted); }
.h-time { display: flex; align-items: center; gap: 0.4rem; font-weight: 600; color: var(--text); }
.h-dot  { width: 7px; height: 7px; background: #22C55E; border-radius: 50%; flex-shrink: 0; }
.emergency-note {
  display: flex; align-items: flex-start; gap: 0.5rem;
  margin-top: 1rem; padding: 0.75rem;
  background: #FFF1F1; border: 1px solid #FEE2E2; border-radius: var(--radius-xs);
  font-size: 0.82rem; color: #B91C1C; line-height: 1.5;
}
.emergency-note svg { flex-shrink: 0; color: #EF4444; margin-top: 1px; }
.emergency-note a { color: #B91C1C; font-weight: 700; }

.quick-btns { display: flex; flex-direction: column; gap: 0.6rem; }
.quick-btn {
  display: flex; align-items: center; gap: 0.85rem;
  padding: 0.75rem 1rem;
  background: #F9FAFB; border: 1px solid var(--border); border-radius: var(--radius-xs);
  transition: var(--transition); color: var(--text);
}
.quick-btn:hover { background: var(--primary-pale); border-color: var(--primary); }
.qb-ico { width: 34px; height: 34px; border-radius: 7px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.qb-phone { background: var(--primary); }
.qb-wa    { background: #25D366; }
.qb-email { background: #F59E0B; }
.quick-btn strong { display: block; font-size: 0.82rem; color: var(--text); line-height: 1.2; }
.quick-btn span   { font-size: 0.75rem; color: var(--text-muted); }

.landmark-abbr { width: 48px; height: 48px; background: var(--primary-pale); color: var(--primary); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.75rem; margin: 0 auto 0.75rem; border: 1px solid rgba(60,131,246,0.2); letter-spacing: 0.05em; }

@media (max-width: 900px) { .location-grid { grid-template-columns: 1fr; } }
@media (max-width: 640px) { .map-embed { height: 280px; } }
</style>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  window.addEventListener('load', () => {
    const map = (window as any).L.map('map').setView([12.9352, 77.6245], 16);
    (window as any).L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    const icon = (window as any).L.divIcon({
      html: `<div style="background:#3C83F6;width:40px;height:40px;border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:3px solid white;box-shadow:0 4px 16px rgba(60,131,246,0.5)"></div>`,
      iconSize: [40, 40],
      iconAnchor: [20, 40],
      className: ''
    });

    (window as any).L.marker([12.9352, 77.6245], { icon })
      .addTo(map)
      .bindPopup('<strong>Bright Smiles Dental Clinic</strong><br/>123 Smile Street, Koramangala, Bengaluru<br/>+91 80-1234 5678')
      .openPopup();
  });
</script>
