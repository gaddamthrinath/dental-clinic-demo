---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact Us" description="Book an appointment at Bright Smiles Dental Clinic, Bengaluru. Contact us via phone, WhatsApp, or email.">

  <div class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">Home</a> <span>/</span> <span>Contact</span></div>
      <h1>Get In Touch</h1>
      <p>Book an appointment or ask us anything. We reply within 24 hours.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="contact-layout">

        <!-- LEFT: FORM -->
        <div class="form-panel" id="appointment">
          <div class="panel-header">
            <div class="panel-icon">
              <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </div>
            <div>
              <h2>Book an Appointment</h2>
              <p class="panel-sub">Fill in your details and we'll confirm shortly.</p>
            </div>
          </div>

          <form class="appt-form" id="appt-form">
            <div class="field-row">
              <div class="form-group">
                <label for="fname">First Name <span class="required">*</span></label>
                <input type="text" id="fname" name="firstName" placeholder="John" required />
              </div>
              <div class="form-group">
                <label for="lname">Last Name</label>
                <input type="text" id="lname" name="lastName" placeholder="Smith" />
              </div>
            </div>

            <div class="form-group">
              <label for="cemail">Email Address <span class="required">*</span></label>
              <div class="input-with-icon">
                <svg class="input-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                </svg>
                <input type="email" id="cemail" name="email" placeholder="john@example.com" required />
              </div>
            </div>

            <div class="form-group">
              <label for="cphone">Phone / WhatsApp <span class="required">*</span></label>
              <div class="input-with-icon">
                <svg class="input-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .84h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.18a16 16 0 006.91 6.91l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
                </svg>
                <input type="tel" id="cphone" name="phone" placeholder="+91 98765 43210" required />
              </div>
            </div>

            <div class="form-group">
              <label for="cservice">Service Required</label>
              <div class="select-wrap">
                <select id="cservice" name="service">
                  <option value="">Select a service...</option>
                  <option>General Check-Up &amp; Cleaning</option>
                  <option>Teeth Whitening</option>
                  <option>Dental Implants</option>
                  <option>Orthodontics / Braces</option>
                  <option>Invisalign</option>
                  <option>Cosmetic Dentistry</option>
                  <option>Root Canal Treatment</option>
                  <option>Tooth Extraction</option>
                  <option>Emergency Dental Care</option>
                  <option>Other</option>
                </select>
                <svg class="select-arrow" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </div>
            </div>

            <div class="field-row">
              <div class="form-group">
                <label for="cdate">Preferred Date</label>
                <input type="date" id="cdate" name="date" />
              </div>
              <div class="form-group">
                <label for="ctime">Preferred Time</label>
                <div class="select-wrap">
                  <select id="ctime" name="time">
                    <option value="">Any time</option>
                    <option>9:00 AM</option>
                    <option>10:00 AM</option>
                    <option>11:00 AM</option>
                    <option>12:00 PM</option>
                    <option>2:00 PM</option>
                    <option>3:00 PM</option>
                    <option>4:00 PM</option>
                    <option>5:00 PM</option>
                    <option>6:00 PM</option>
                  </select>
                  <svg class="select-arrow" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </div>
              </div>
            </div>

            <div class="form-group">
              <label for="cmessage">Additional Notes</label>
              <textarea id="cmessage" name="message" placeholder="Tell us about any dental concerns, allergies, or special requirements..."></textarea>
            </div>

            <button type="submit" class="btn btn--primary submit-btn" id="submit-btn">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
              </svg>
              Request Appointment
            </button>

            <div id="form-success" class="success-msg" style="display:none;">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              Thank you! We will confirm your appointment within 24 hours.
            </div>
          </form>
        </div>

        <!-- RIGHT: SIDEBAR -->
        <div class="contact-sidebar">

          <!-- WhatsApp -->
          <a href="https://wa.me/919912837875?text=Hi%2C%20I%20want%20to%20enquire%20about%20your%20web%20development%20services%20for%20my%20dental%20clinic." target="_blank" class="channel-card wa-card" id="contact-wa-btn">
            <div class="channel-left">
              <div class="channel-ico wa-ico">
                <svg width="24" height="24" fill="white" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <strong>WhatsApp</strong>
                <span>+91 98765 43210</span>
              </div>
            </div>
            <svg class="channel-arrow" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>

          <!-- Email -->
          <a href="mailto:hello@brightsmilesdental.in?subject=Appointment Request" class="channel-card email-card" id="contact-email-btn">
            <div class="channel-left">
              <div class="channel-ico email-ico">
                <svg width="22" height="22" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
              <div>
                <strong>Email Us</strong>
                <span>hello@brightsmilesdental.in</span>
              </div>
            </div>
            <svg class="channel-arrow" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>

          <!-- Phone -->
          <a href="tel:+918012345678" class="channel-card phone-card" id="contact-phone-btn">
            <div class="channel-left">
              <div class="channel-ico phone-ico">
                <svg width="20" height="20" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .84h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.18a16 16 0 006.91 6.91l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
                </svg>
              </div>
              <div>
                <strong>Call Us</strong>
                <span>+603-1234 5678</span>
              </div>
            </div>
            <svg class="channel-arrow" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>

          <!-- Hours -->
          <div class="hours-panel">
            <h4>
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="display:inline;vertical-align:middle;margin-right:0.4rem;">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
              Clinic Hours
            </h4>
            <div class="hours-rows">
              {[
                ['Monday — Friday', '9:00 AM – 7:00 PM', true],
                ['Saturday',        '9:00 AM – 4:00 PM', true],
                ['Sunday',          'Closed',             false],
              ].map(([day, time, open]) => (
                <div class="h-row">
                  <span class="h-day">{day}</span>
                  <span class={`h-time ${!open ? 'h-closed' : ''}`}>{time}</span>
                </div>
              ))}
            </div>
            <div class="emergency-strip">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
              <span>Dental emergency? Call us anytime — <a href="tel:+60312345678">+603-1234 5678</a></span>
            </div>
          </div>

          <!-- Address -->
          <div class="address-panel">
            <h4>
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="display:inline;vertical-align:middle;margin-right:0.4rem;">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              Our Address
            </h4>
            <address>
              Bright Smiles Dental Clinic<br/>
              123 Smile Street, Koramangala<br/>
              Bengaluru, Karnataka 560034<br/>
              India
            </address>
            <a href="https://maps.google.com/?q=Koramangala+Bengaluru" target="_blank" class="btn btn--outline" style="width:100%;margin-top:1rem;font-size:0.85rem;">
              View on Google Maps
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">FAQ</div>
        <h2>Frequently Asked Questions</h2>
        <div class="divider"></div>
      </div>
      <div class="faq-grid">
        {[
          { q: 'How do I book an appointment?', a: 'You can book via the form above, call us at +91 80-1234 5678, or message us on WhatsApp. We typically confirm within 2 hours during working hours.' },
          { q: 'Do you accept walk-in patients?', a: 'Yes we do accept walk-ins, but we recommend booking ahead to minimise waiting time, especially for specialist consultations.' },
          { q: 'Is there parking available?', a: 'Yes! Free parking is available in our clinic premises. Additional street parking is available in Koramangala 6th Block.' },
          { q: 'Do you treat children?', a: 'Absolutely. We have a child-friendly treatment area and our dentists are specially trained to treat young patients comfortably.' },
          { q: 'Is sedation dentistry available?', a: 'Yes. We offer nitrous oxide and oral sedation for anxious patients. Please mention this when booking.' },
          { q: 'Do you accept insurance?', a: 'Yes. We accept all major health insurance plans and corporate tie-ups. We also offer easy EMI options for larger treatments.' },
        ].map(f => (
          <div class="faq-card">
            <h4>{f.q}</h4>
            <p>{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
/* ── CONTACT LAYOUT ─────────────────────────── */
.contact-layout {
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: 2rem;
  align-items: start;
}

/* ── FORM PANEL ─────────────────────────────── */
.form-panel {
  background: white;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 2rem;
  box-shadow: var(--shadow-card);
}
.panel-header {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  margin-bottom: 2rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--border);
}
.panel-icon {
  width: 48px;
  height: 48px;
  background: var(--primary-pale);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
  flex-shrink: 0;
}
.panel-header h2 { font-size: 1.35rem; margin-bottom: 0.2rem; }
.panel-sub { font-size: 0.88rem; color: var(--text-muted); margin: 0; }

/* ── FORM FIELDS ─────────────────────────────── */
.field-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}
.required { color: #EF4444; font-weight: 700; margin-left: 2px; }

.input-with-icon { position: relative; }
.input-icon {
  position: absolute;
  left: 0.85rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-light);
  pointer-events: none;
  z-index: 1;
}
.input-with-icon input { padding-left: 2.5rem; }

.select-wrap { position: relative; }
.select-wrap select { padding-right: 2.5rem; cursor: pointer; }
.select-arrow {
  position: absolute;
  right: 0.85rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-light);
  pointer-events: none;
}

.appt-form .form-group input,
.appt-form .form-group textarea,
.appt-form .form-group select {
  border-radius: var(--radius-xs);
  font-size: 0.92rem;
  padding: 0.72rem 1rem;
  background: #FAFAFA;
}
.appt-form .form-group input:focus,
.appt-form .form-group textarea:focus,
.appt-form .form-group select:focus {
  background: white;
}

.submit-btn {
  width: 100%;
  padding: 0.9rem 1.5rem;
  font-size: 0.95rem;
  border-radius: var(--radius-sm);
  margin-top: 0.5rem;
  gap: 0.6rem;
}
.success-msg {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  background: #ECFDF5;
  border: 1px solid #A7F3D0;
  border-radius: var(--radius-xs);
  padding: 0.9rem 1rem;
  color: #065F46;
  font-size: 0.9rem;
  font-weight: 500;
  margin-top: 1rem;
}

/* ── SIDEBAR ─────────────────────────────────── */
.contact-sidebar { display: flex; flex-direction: column; gap: 0.85rem; }

.channel-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.1rem 1.25rem;
  background: white;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  transition: var(--transition);
  text-decoration: none;
  color: var(--text);
  box-shadow: var(--shadow-card);
}
.channel-card:hover {
  border-color: var(--primary);
  box-shadow: 0 2px 12px rgba(60,131,246,0.12);
  transform: translateY(-2px);
}
.channel-left {
  display: flex;
  align-items: center;
  gap: 0.85rem;
}
.channel-ico {
  width: 44px;
  height: 44px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.wa-ico    { background: #25D366; }
.email-ico { background: var(--primary); }
.phone-ico { background: #F59E0B; }

.channel-left strong { display: block; font-size: 0.88rem; color: var(--text); line-height: 1.3; }
.channel-left span   { font-size: 0.8rem; color: var(--text-muted); }
.channel-arrow { color: var(--text-light); flex-shrink: 0; }

.hours-panel,
.address-panel {
  background: white;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 1.35rem;
  box-shadow: var(--shadow-card);
}
.hours-panel h4, .address-panel h4 {
  font-size: 0.92rem;
  margin-bottom: 1rem;
  color: var(--text);
}
.hours-rows { display: flex; flex-direction: column; gap: 0; }
.h-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.5rem 0;
  border-bottom: 1px solid var(--border);
  font-size: 0.83rem;
}
.h-row:last-child { border-bottom: none; }
.h-day   { color: var(--text-muted); }
.h-time  { font-weight: 600; color: var(--text); }
.h-closed { color: #EF4444 !important; }

.emergency-strip {
  display: flex;
  align-items: flex-start;
  gap: 0.5rem;
  margin-top: 1rem;
  padding: 0.75rem;
  background: #FFF1F1;
  border: 1px solid #FEE2E2;
  border-radius: var(--radius-xs);
  font-size: 0.8rem;
  color: #B91C1C;
  line-height: 1.5;
}
.emergency-strip svg { flex-shrink: 0; margin-top: 1px; color: #EF4444; }
.emergency-strip a   { color: #B91C1C; font-weight: 600; text-decoration: underline; }

address {
  font-style: normal;
  font-size: 0.88rem;
  line-height: 1.8;
  color: var(--text-muted);
}

/* ── FAQ ─────────────────────────────────────── */
.faq-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
}
.faq-card {
  background: white;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 1.5rem;
  box-shadow: var(--shadow-card);
  transition: var(--transition);
}
.faq-card:hover { border-color: rgba(60,131,246,0.25); box-shadow: var(--shadow-md); }
.faq-card h4 { font-size: 0.95rem; margin-bottom: 0.6rem; color: var(--text); }
.faq-card p  { font-size: 0.875rem; line-height: 1.7; }

/* ── RESPONSIVE ─────────────────────────────── */
@media (max-width: 1024px) {
  .contact-layout { grid-template-columns: 1fr; }
  .contact-sidebar {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
  }
  .hours-panel, .address-panel { grid-column: span 2; }
}
@media (max-width: 768px) {
  .faq-grid { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
  .form-panel { padding: 1.35rem; }
  .field-row  { grid-template-columns: 1fr; gap: 0; }
  .contact-sidebar { grid-template-columns: 1fr; }
  .hours-panel, .address-panel { grid-column: span 1; }
  .panel-header { flex-direction: column; gap: 0.6rem; }
  .panel-header h2 { font-size: 1.2rem; }
}
</style>

<script>
  const form = document.getElementById('appt-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const success = document.getElementById('form-success') as HTMLElement;
    btn.textContent = 'Sending...';
    btn.disabled = true;
    setTimeout(() => {
      success.style.display = 'flex';
      btn.style.display = 'none';
      form.reset();
    }, 1400);
  });
</script>
