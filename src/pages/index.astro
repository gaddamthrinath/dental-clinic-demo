---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Home" description="Bright Smiles Dental Clinic — Premium, compassionate dental care in Kuala Lumpur. Book your appointment today.">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/images/hero.png" alt="Bright Smiles Dental Clinic" class="hero-img" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-pill">Rated #1 Dental Clinic in KL</div>
      <h1 class="hero-title font-serif">
        Your Perfect Smile<br/><span class="hero-hl">Starts Here</span>
      </h1>
      <p class="hero-desc">Compassionate, comprehensive dental care for the whole family. State-of-the-art technology with a gentle, caring touch.</p>
      <div class="hero-actions">
        <a href="/contact#appointment" class="btn btn--white btn--lg" id="hero-book-btn">Book Appointment</a>
        <a href="https://wa.me/919876543210?text=Hi%2C%20I%20want%20to%20book%20an%20appointment" target="_blank" class="btn btn--whatsapp btn--lg" id="hero-wa-btn">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp Us
        </a>
      </div>
      <div class="hero-stats">
        <div class="stat"><span class="sn">5000+</span><span class="sl">Happy Patients</span></div>
        <div class="stat-div"></div>
        <div class="stat"><span class="sn">20+</span><span class="sl">Years Experience</span></div>
        <div class="stat-div"></div>
        <div class="stat"><span class="sn">12+</span><span class="sl">Specialists</span></div>
        <div class="stat-div"></div>
        <div class="stat"><span class="sn">98%</span><span class="sl">Satisfaction Rate</span></div>
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE US -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">Why Choose Us</div>
        <h2>Dental Care You Can Trust</h2>
        <div class="divider"></div>
        <p>We combine cutting-edge technology with a warm, patient-first approach to deliver exceptional dental experiences.</p>
      </div>
      <div class="grid-4">
        {[
          { title: 'Award-Winning Care', desc: 'Recognized as a Top Dental Clinic in India for 5 consecutive years.', svg: '<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>' },
          { title: 'Advanced Technology', desc: 'Digital X-rays, 3D scanning, and laser dentistry for precise, comfortable treatments.', svg: '<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>' },
          { title: 'Gentle & Caring', desc: 'We prioritize your comfort. Sedation dentistry available for anxious patients.', svg: '<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>' },
          { title: 'Flexible Hours', desc: 'Extended weekday and Saturday appointments to fit your busy schedule.', svg: '<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' },
        ].map(f => (
          <div class="feature-card card">
            <div class="feature-ico" set:html={f.svg}></div>
            <h4>{f.title}</h4>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES PREVIEW -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">Our Services</div>
        <h2>Comprehensive Dental Services</h2>
        <div class="divider"></div>
        <p>From routine check-ups to smile transformations — everything your family needs under one roof.</p>
      </div>
      <div class="grid-3">
        {[
          { img: '/images/teeth-whitening.png', title: 'Teeth Whitening', desc: 'Professional whitening treatments for a brilliantly brighter smile in just one visit.', href: '/services#whitening' },
          { img: '/images/treatment-room.png',  title: 'Dental Implants', desc: 'Permanent, natural-looking tooth replacements that restore your smile and confidence.', href: '/services#implants' },
          { img: '/images/xray.png',            title: 'Digital X-Rays',  desc: 'State-of-the-art digital imaging for accurate diagnosis with minimal radiation.', href: '/services#xray' },
        ].map(s => (
          <a href={s.href} class="service-card card">
            <div class="sc-img-wrap">
              <img src={s.img} alt={s.title} class="sc-img" />
            </div>
            <div class="sc-body">
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
              <span class="sc-link">Learn More
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.5rem;">
        <a href="/services" class="btn btn--primary">View All Services</a>
      </div>
    </div>
  </section>

  <!-- ABOUT SNIPPET -->
  <section class="section">
    <div class="container about-split">
      <div class="about-img-side">
        <img src="/images/team.png" alt="Our dental team" class="about-img" />
        <div class="about-badge">
          <div class="ab-icon">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M12 2C8.5 2 6 5 6 7.5c0 1.8.7 3.3 1.8 4.5l.8 5c.25 1.3 1.3 1.8 2.2 1.8h2.4c.9 0 1.95-.5 2.2-1.8l.8-5c1.1-1.2 1.8-2.7 1.8-4.5C18 5 15.5 2 12 2z"/>
            </svg>
          </div>
          <div>
            <strong>Est. 2005</strong>
            <span>Trusted for 20+ years</span>
          </div>
        </div>
      </div>
      <div class="about-text-side">
        <div class="section-tag">About Bright Smiles</div>
        <h2 class="font-serif">A Clinic Built on<br/><em style="color:var(--primary);font-style:italic;">Compassion & Excellence</em></h2>
        <div class="divider divider--left"></div>
        <p>Founded in 2005, Bright Smiles Dental Clinic has been a cornerstone of oral health in Kuala Lumpur. Our team of dedicated specialists brings together decades of experience with the latest dental technologies.</p>
        <p style="margin-top:0.85rem;">We believe every patient deserves a personalized experience — from the moment you walk in, to long after you leave with your beautiful smile.</p>
        <div class="about-stats">
          <div class="as-item"><span class="stat-number">5000+</span><span class="as-label">Smiles Transformed</span></div>
          <div class="as-item"><span class="stat-number">12</span><span class="as-label">Expert Dentists</span></div>
          <div class="as-item"><span class="stat-number">20+</span><span class="as-label">Years of Trust</span></div>
        </div>
        <a href="/about" class="btn btn--primary" style="margin-top:2rem;">Meet Our Team</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section section--dark">
    <div class="container">
      <div class="section-header">
        <div class="section-tag" style="background:rgba(255,255,255,0.15);color:white;border-color:rgba(255,255,255,0.2);">Patient Stories</div>
        <h2>What Our Patients Say</h2>
        <div class="divider" style="background:rgba(255,255,255,0.4);"></div>
      </div>
      <div class="grid-3">
        {[
          { name: 'Priya S.', role: 'Teacher, Koramangala', quote: 'I had severe dental anxiety but the team at Bright Smiles made me feel so calm. My teeth look amazing now!' },
          { name: 'Rahul M.', role: 'Software Engineer, HSR Layout', quote: 'Got my implants done here. The whole process was smooth, professional, and the result is absolutely natural-looking.' },
          { name: 'Ananya K.', role: 'Doctor, Indiranagar', quote: 'Best dental clinic in Bengaluru. The whitening results were incredible and the staff were incredibly friendly throughout.' },
        ].map(t => (
          <div class="testimonial-card">
            <div class="stars">★★★★★</div>
            <p class="tq">"{t.quote}"</p>
            <div class="ta">
              <div class="ta-avatar">{t.name[0]}</div>
              <div>
                <strong>{t.name}</strong>
                <span>{t.role}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA STRIP -->
  <section class="cta-strip">
    <div class="container cta-inner">
      <div class="cta-text">
        <h2>Ready for Your Best Smile?</h2>
        <p>First-time patients receive a <strong>FREE check-up and X-ray</strong> — no strings attached.</p>
      </div>
      <div class="cta-btns">
        <a href="/contact#appointment" class="btn btn--white" id="cta-book-btn">Book Free Check-Up</a>
        <a href="https://wa.me/919876543210" target="_blank" class="btn btn--whatsapp" id="cta-wa-btn">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
/* HERO */
.hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  align-items: center;
  padding-top: var(--nav-height);
  overflow: hidden;
}
.hero-bg { position: absolute; inset: 0; }
.hero-img { width: 100%; height: 100%; object-fit: cover; }
.hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(135deg,
    rgba(29,78,216,0.90) 0%,
    rgba(60,131,246,0.75) 55%,
    rgba(96,165,250,0.55) 100%);
}
.hero-content {
  position: relative; z-index: 2;
  padding: 4rem 1.25rem 3rem;
  max-width: 740px;
}
.hero-pill {
  display: inline-flex;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.25);
  border-radius: 100px;
  padding: 0.35rem 0.9rem;
  font-size: 0.8rem;
  color: white;
  font-weight: 600;
  margin-bottom: 1.25rem;
  letter-spacing: 0.02em;
}
.hero-title {
  font-size: clamp(2.2rem, 5.5vw, 4rem);
  color: white;
  line-height: 1.1;
  margin-bottom: 1.1rem;
  letter-spacing: -0.03em;
}
.hero-hl {
  background: linear-gradient(135deg, #93C5FD, #BAE6FD);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero-desc { color: rgba(255,255,255,0.88); font-size: 1.05rem; max-width: 520px; margin-bottom: 2rem; }
.hero-actions { display: flex; gap: 0.85rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
.hero-stats {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: var(--radius-sm);
  padding: 1rem 1.5rem;
  flex-wrap: wrap;
  gap: 1rem;
}
.stat { text-align: center; }
.sn { display: block; font-size: 1.5rem; font-weight: 900; color: white; line-height: 1; }
.sl { font-size: 0.72rem; color: rgba(255,255,255,0.7); font-weight: 500; margin-top: 0.15rem; display: block; }
.stat-div { width: 1px; height: 32px; background: rgba(255,255,255,0.2); flex-shrink: 0; }

/* FEATURES */
.feature-card { padding: 1.75rem; text-align: center; }
.feature-ico { width: 56px; height: 56px; background: var(--primary-pale); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: var(--primary); margin: 0 auto 1.1rem; }
.feature-card h4 { margin-bottom: 0.5rem; font-size: 1rem; }
.feature-card p  { font-size: 0.88rem; }

/* SERVICE CARDS */
.service-card { display: block; }
.sc-img-wrap { aspect-ratio: 16/10; overflow: hidden; }
.sc-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
.service-card:hover .sc-img { transform: scale(1.05); }
.sc-body { padding: 1.35rem; }
.sc-body h3 { font-size: 1.1rem; margin-bottom: 0.4rem; }
.sc-body p  { font-size: 0.88rem; }
.sc-link { display: inline-flex; align-items: center; gap: 0.25rem; margin-top: 0.85rem; color: var(--primary); font-weight: 600; font-size: 0.88rem; transition: var(--transition); }
.service-card:hover .sc-link { gap: 0.45rem; }

/* ABOUT */
.about-split { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
.about-img-side { position: relative; }
.about-img { border-radius: var(--radius-md); box-shadow: var(--shadow-lg); width: 100%; }
.about-badge {
  position: absolute;
  bottom: -1.25rem; right: -1.25rem;
  background: white;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 0.85rem 1.25rem;
  box-shadow: var(--shadow-md);
  display: flex; align-items: center; gap: 0.75rem;
}
.ab-icon { width: 40px; height: 40px; background: var(--primary-pale); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--primary); flex-shrink: 0; }
.about-badge strong { display: block; font-size: 0.9rem; color: var(--text); line-height: 1.2; }
.about-badge span   { font-size: 0.78rem; color: var(--text-muted); }
.about-text-side h2 { margin: 0.6rem 0; }
.about-stats { display: flex; gap: 2rem; margin-top: 1.75rem; flex-wrap: wrap; }
.as-item { display: flex; flex-direction: column; }
.as-label { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.2rem; }

/* TESTIMONIALS */
.testimonial-card {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: var(--radius-md);
  padding: 1.75rem;
  transition: var(--transition);
}
.testimonial-card:hover { background: rgba(255,255,255,0.1); transform: translateY(-3px); }
.stars { color: #FBBF24; font-size: 0.95rem; letter-spacing: 0.05em; margin-bottom: 0.85rem; }
.tq { font-style: italic; font-size: 0.92rem; line-height: 1.8; color: rgba(255,255,255,0.85); margin-bottom: 1.35rem; }
.ta { display: flex; align-items: center; gap: 0.75rem; }
.ta-avatar { width: 40px; height: 40px; background: var(--primary-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; color: white; font-size: 1rem; flex-shrink: 0; }
.ta strong { display: block; color: white; font-size: 0.9rem; }
.ta span   { font-size: 0.78rem; color: rgba(255,255,255,0.6); }

/* CTA STRIP */
.cta-strip {
  background: linear-gradient(135deg, var(--primary-dark), var(--primary));
  padding: 3.5rem 0;
}
.cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
.cta-text h2 { color: white; margin-bottom: 0.35rem; font-size: 1.6rem; }
.cta-text p  { color: rgba(255,255,255,0.85); }
.cta-btns { display: flex; gap: 0.85rem; flex-wrap: wrap; flex-shrink: 0; }

@media (max-width: 900px) {
  .about-split { grid-template-columns: 1fr; gap: 2.5rem; }
  .about-badge { position: static; display: inline-flex; margin-top: 1rem; }
  .cta-inner { flex-direction: column; text-align: center; }
  .cta-btns { justify-content: center; }
  .stat-div { display: none; }
  .hero-stats { justify-content: center; }
}
@media (max-width: 640px) {
  .hero-actions { flex-direction: column; }
  .hero-actions .btn { width: 100%; }
  .about-stats { gap: 1.5rem; }
}
</style>
