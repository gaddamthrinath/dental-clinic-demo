<style>
.footer { background: #0F172A; color: rgba(255,255,255,0.65); }
.footer-top { padding: 4.5rem 0 2.5rem; }
.footer-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
  gap: 3rem;
}

/* BRAND */
.f-logo { display: flex; align-items: center; gap: 0.65rem; margin-bottom: 0.75rem; text-decoration: none; }
.f-logo-mark { width: 38px; height: 38px; background: var(--primary); border-radius: 9px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.f-logo-name { font-weight: 800; font-size: 0.9rem; color: white; line-height: 1.2; }
.f-logo-sub  { font-size: 0.66rem; color: rgba(255,255,255,0.45); }
.footer-brand p { font-size: 0.85rem; line-height: 1.8; color: rgba(255,255,255,0.5); margin-bottom: 1.25rem; }
.f-socials { display: flex; gap: 0.6rem; }
.f-social {
  width: 32px; height: 32px;
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 7px;
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,0.55);
  transition: var(--transition);
}
.f-social:hover { background: var(--primary); border-color: var(--primary); color: white; }
.f-social--wa:hover { background: #25D366; border-color: #25D366; }

/* LINKS */
.f-heading { color: white; font-size: 0.85rem; font-weight: 700; margin-bottom: 1.1rem; letter-spacing: 0.02em; }
.f-links { display: flex; flex-direction: column; gap: 0.5rem; }
.f-links a { color: rgba(255,255,255,0.5); font-size: 0.85rem; transition: var(--transition); }
.f-links a:hover { color: var(--primary-light); }

/* CONTACT */
.f-contact { display: flex; flex-direction: column; gap: 0.85rem; }
.f-contact li { display: flex; gap: 0.6rem; font-size: 0.82rem; color: rgba(255,255,255,0.5); line-height: 1.6; align-items: flex-start; }
.f-contact svg { flex-shrink: 0; margin-top: 2px; color: var(--primary-light); }
.f-contact a { color: rgba(255,255,255,0.5); transition: var(--transition); }
.f-contact a:hover { color: var(--primary-light); }

/* BOTTOM */
.footer-bottom { border-top: 1px solid rgba(255,255,255,0.07); padding: 1.25rem 0; }
.f-bottom-inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
.f-bottom-inner p { font-size: 0.8rem; color: rgba(255,255,255,0.35); }

@media (max-width: 1024px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 2.5rem; } }
@media (max-width: 640px)  { .footer-grid { grid-template-columns: 1fr; gap: 2rem; } .f-bottom-inner { flex-direction: column; text-align: center; } }
</style>
